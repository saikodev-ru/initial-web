# ── Initial Messenger — Root Apache config ──

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    Options -Indexes -MultiViews

    # ── Profile URL: /@username → u.php?u=username ──
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^@([a-zA-Z0-9_]+)/?$ u.php?u=$1 [QSA,L]

    # ── Profile URL: /u/username → u.php?u=username ──
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^u/([a-zA-Z0-9_]+)/?$ u.php?u=$1 [QSA,L]
</IfModule>

# ── Fallback: catch-all 404 → u.php (for edge cases) ──
ErrorDocument 404 /u.php

# ── Gzip compression ──
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# ── Security: block access to sensitive files ──
<FilesMatch "^(config\.php|\.env|security\.php|s3_helper\.php|helpers\.php|db\.php)$">
    Order allow,deny
    Deny from all
</FilesMatch>
