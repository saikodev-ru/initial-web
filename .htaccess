# ── Initial Messenger — Root Apache config ──

# ── Profile URLs: /u/username → /u/index.php?u=username ──────
<IfModule mod_rewrite.c>
    RewriteEngine On
    Options -Indexes -MultiViews

    # Route /u/username to the profile page
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^u/([a-zA-Z0-9_]+)/?$ /u/index.php?u=$1 [QSA,L]
</IfModule>

# ── Ensure PHP is processed in all directories ──
<FilesMatch \.php$>
    SetHandler application/x-httpd-php
</FilesMatch>

# ── Gzip compression ──
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# ── Security: block access to sensitive files ──
<FilesMatch "^(config\.php|\.env|\.htaccess|security\.php|s3_helper\.php|helpers\.php|db\.php)$">
    Order allow,deny
    Deny from all
</FilesMatch>
