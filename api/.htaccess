<IfModule mod_rewrite.c>
    RewriteEngine On

    # Отключаем MultiViews, чтобы Apache не делал самовольных 301 редиректов,
    # которые "теряют" заголовок Authorization.
    Options -MultiViews

    # Принудительно передаем заголовок авторизации в PHP-скрипт.
    # Это критически важно для многих хостингов.
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Все запросы направляем через роутер index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# ── Запретить доступ к критичным файлам ─────────────────────────
<FilesMatch "^(config\.php|pulse_db\.php|push_config\.php|db\.php|\.env|security\.php|s3_helper\.php|helpers\.php)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ── Запретить доступ к логам и временным файлам ─────────────────
<FilesMatch "\.(log|tmp|bak|swp|old)$">
    Order allow,deny
    Deny from all
</FilesMatch>
