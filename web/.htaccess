# Signal Messenger — Apache config

# ── JS/CSS: no cache (always reload fresh) ─────────────────────
<FilesMatch "\.(js|css)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
</FilesMatch>

# ── Images/fonts: cache 1 week ──────────────────────────────────
<FilesMatch "\.(png|jpg|jpeg|gif|webp|svg|ico|ttf|woff|woff2)$">
    Header set Cache-Control "public, max-age=604800"
</FilesMatch>

# ── Gzip compression ────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# ── Pretty URLs ─────────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    Options -Indexes

    # ── Profile URLs handled by /u/ directory at project root ──
    # initial.su/u/username → /u/index.php?u=username
</IfModule>
